# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-DEF...

# Only messages from this chat ID will be processed (int64).
# Get it by messaging @userinfobot or enabling debug logs.
TELEGRAM_CHAT_ID=123456789

# Host directory where markdown notes are stored. Mounted into the
# container at /notes (see docker-compose.yml).
NOTES_HOST_PATH=/absolute/path/on/host/notes

# Groq API credentials (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override the default system prompt used to refine notes.
# Leave unset to use the built-in default.
# GROQ_SYSTEM_PROMPT=
